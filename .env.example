# ODS — environment configuration template
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Source (core_banking) database
DB_SOURCE_HOST=127.0.0.1
DB_SOURCE_PORT=5432
DB_SOURCE_NAME=core_banking

# ODS database
DB_ODS_HOST=127.0.0.1
DB_ODS_PORT=5433
DB_ODS_NAME=ods

# Shared credentials (used by both databases in this PoC)
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ODS DB host as seen from inside Docker (transformer uses this)
DB_ODS_DOCKER_HOST=ods-db
